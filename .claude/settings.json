{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/scripts/pre-session-summary.sh",
            "timeout": 30,
            "statusMessage": "Running pre-session setup..."
          }
        ]
      }
    ]
  }
}
